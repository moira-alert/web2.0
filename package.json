{
    "name": "moira-front",
    "version": "1.1.0",
    "license": "MIT",
    "private": true,
    "type": "module",
    "scripts": {
        "prepare": "husky install",
        "prepare:lezer": "lezer-generator src/TriggerGrammar/TriggerGrammar.grammar -o src/TriggerGrammar/parser.ts",
        "serve": "vite dev",
        "start": "concurrently \"yarn serve --config vite.config.mock-api.ts\" \"yarn fakeapi\"",
        "start:dev-proxy": "yarn serve --config vite.config.dev-proxy.ts",
        "start:port-forward": "yarn serve --config vite.config.port-forward.ts",
        "start:docker": "concurrently \"yarn backend\" \"yarn start:docker-proxy\"",
        "start:docker-proxy": "yarn serve --config vite.config.docker-proxy.ts",
        "backend": "docker compose -f src/tests/core/api/docker-compose.yml down --rmi all && docker compose -f src/tests/core/api/docker-compose.yml up",
        "build": "vite build",
        "storybook": "cross-env NODE_ENV=development storybook dev -p 9001 -c .storybook --ci ",
        "storybook:ci": "yarn storybook --ci --quiet",
        "fakeapi": "json-server --watch fakeapi/db.json --routes fakeapi/routes.json --port 9002",
        "lint": "eslint \"src/**/*.{ts,tsx}\"",
        "test": "cross-env NODE_ENV=testing jest \"./src\"",
        "test:e2e": "concurrently -k -s first \"yarn start:docker\" \"wait-on http://localhost:8080 && npx playwright test e2eTests/\"",
        "prettier": "prettier \"./src/**/*.{ts,tsx}\"",
        "pw:screenshotTest": "cross-env SKIP_SETUP=true xvfb-run npx playwright test screenshotTests/screenshotTest.spec.ts",
        "screenshots": "concurrently -k -s first \"yarn storybook:ci\" \"wait-on http://localhost:9001 && yarn pw:screenshotTest\"",
        "generate-types": "node generateTypes.js"
    },
    "dependencies": {
        "@reduxjs/toolkit": "2.2.1",
        "@sentry/react": "10.57.0",
        "@skbkontur-moira/codemirror-metricsql": "0.0.1-dev.1809240003",
        "@skbkontur/icons": "2.0.10",
        "@skbkontur/markdown": "2.7.0",
        "@skbkontur/react-stack-layout": "1.0.3",
        "@skbkontur/react-ui": "6.0.8",
        "@skbkontur/react-ui-validations": "3.0.2",
        "@tanstack/react-table": "8.17.3",
        "@types/codemirror": "5.60.1",
        "@vitejs/plugin-react": "6.0.2",
        "chart.js": "4.5.1",
        "chartjs-adapter-date-fns": "3.0.0",
        "chartjs-plugin-zoom": "2.2.0",
        "codemirror": "6.0.1",
        "color-hash": "1.0.3",
        "date-fns": "2.9.0",
        "dompurify": "3.4.9",
        "file-saver": "2.0.2",
        "lodash": "4.18.1",
        "numeral": "2.0.6",
        "qs": "6.15.2",
        "query-string": "6.4.0",
        "react": "19.2.7",
        "react-animate-height": "3.2.3",
        "react-chartjs-2": "5.3.1",
        "react-dom": "19.2.7",
        "react-redux": "9.3.0",
        "react-router": "7.17.0",
        "react-virtualized-auto-sizer": "2.0.3",
        "reflect-metadata": "0.1.13",
        "uuid": "14.0.0",
        "vite-plugin-pwa": "1.3.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "@lezer/generator": "1.8.0",
        "@playwright/test": "1.60.0",
        "@storybook/react-vite": "10.4.2",
        "@types/classnames": "2.2.10",
        "@types/color-hash": "1.0.0",
        "@types/file-saver": "2.0.1",
        "@types/jest": "30.0.0",
        "@types/lodash": "4.14.159",
        "@types/numeral": "0.0.28",
        "@types/qs": "6.14.0",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "classnames": "2.2.6",
        "jest": "30.4.2",
        "concurrently": "9.1.2",
        "cross-env": "7.0.3",
        "dotenv": "16.3.1",
        "eslint": "9.0.0",
        "eslint-config-prettier": "9.0.0",
        "eslint-plugin-import": "2.32.0",
        "eslint-plugin-prettier": "^5.0.0",
        "eslint-plugin-react": "7.37.5",
        "eslint-plugin-react-hooks": "5.0.0",
        "eslint-plugin-storybook": "10.4.2",
        "husky": "8.0.3",
        "json-server": "0.17.4",
        "less": "4.2.0",
        "mockdate": "3.0.2",
        "prettier": "3.8.3",
        "react-window": "2.2.7",
        "storybook": "10.4.2",
        "swagger-typescript-api": "13.12.2",
        "ts-jest": "^29.4.11",
        "typescript": "5.2.2",
        "typescript-eslint": "8.59.2",
        "vite": "8.0.16",
        "wait-on": "8.0.3"
    },
    "resolutions": {
        "@codemirror/autocomplete": "^6.7.1",
        "@codemirror/language": "^6.3.7",
        "@codemirror/lint": "^6.2.2",
        "@codemirror/state": "^6.2.1",
        "@codemirror/view": "^6.13.0",
        "@lezer/common": "^1.0.3",
        "@lezer/highlight": "^1.1.6",
        "@lezer/lr": "^1.3.6"
    }
}
